{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug",
      "request": "launch",
      "type": "dart",
      "toolArgs": [
        "--dart-define=cronetHttpNoPlay=true"
      ],
    },
    {
      "name": "Debug with Firebase",
      "request": "launch",
      "type": "dart",
      "toolArgs": [
        "--dart-define=USE_FIREBASE=true",
        "--dart-define=cronetHttpNoPlay=true"
      ],
    },
    {
      "name": "Profile",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "toolArgs": [
        "--dart-define=cronetHttpNoPlay=true"
      ],
    },
    {
      "name": "Profile with Firebase",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "toolArgs": [
        "--dart-define=USE_FIREBASE=true",
        "--dart-define=cronetHttpNoPlay=true"
      ],
    },
    {
      "name": "Release",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define=cronetHttpNoPlay=true"
      ],
    },
    {
      "name": "Release with Firebase",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define=USE_FIREBASE=true",
        "--dart-define=cronetHttpNoPlay=true"
      ],
    },
  ]
}
